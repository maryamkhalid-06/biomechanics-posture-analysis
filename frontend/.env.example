# Leave this empty when the FastAPI backend serves the frontend at http://127.0.0.1:8000
# VITE_API_BASE_URL=

# Use this when running the Vite dev server separately while the backend stays local
VITE_API_BASE_URL=http://127.0.0.1:8000

# Example deployed backend:
# VITE_API_BASE_URL=https://your-backend.example.com
